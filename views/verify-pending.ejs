<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Email — FIRTA</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-body">
<div style="min-height:100vh;display:grid;place-items:center;padding:2rem;background:var(--bg)">
  <div style="max-width:480px;width:100%;text-align:center">
    <div style="width:80px;height:80px;background:var(--teal-light);border-radius:50%;display:grid;place-items:center;margin:0 auto 1.5rem">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </div>
    <h1 style="font-family:'Sora',sans-serif;font-size:1.8rem;font-weight:700;margin-bottom:0.75rem">Check your inbox!</h1>
    <% if (typeof resent !== 'undefined' && resent) { %>
    <div class="alert alert-success" style="margin-bottom:1rem">Verification email resent!</div>
    <% } %>
    <p style="color:var(--text-2);margin-bottom:0.5rem">We sent a verification link to:</p>
    <p style="font-weight:700;color:var(--teal);font-size:1.05rem;margin-bottom:1.5rem"><%= email %></p>
    <p style="color:var(--text-2);font-size:0.9rem;line-height:1.6;margin-bottom:2rem">
      Click the link in the email to activate your account.<br>The link expires in <strong>24 hours</strong>.
    </p>
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;margin-bottom:1.5rem">
      <p style="font-size:0.88rem;color:var(--text-2);margin-bottom:1rem">Didn't receive it? Check your spam folder or resend:</p>
      <form action="/resend-verification" method="POST">
        <input type="hidden" name="email" value="<%= email %>">
        <button type="submit" class="btn btn-outline btn-sm" style="width:100%;justify-content:center">
          Resend Verification Email
        </button>
      </form>
    </div>
    <a href="/login" style="color:var(--text-muted);font-size:0.88rem">← Back to Login</a>
  </div>
</div>
</body>
</html>
