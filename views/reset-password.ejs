<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password — FIRTA</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-body">
<div class="auth-layout">
  <div class="auth-left">
    <div class="auth-left-overlay"></div>
    <div class="auth-left-content">
      <div class="auth-logo">
        <div class="auth-logo-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="white" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></div>
        FIRTA
      </div>
      <div class="auth-left-hero">
        <h1>Create a new<br>password.</h1>
        <p>Choose something strong — at least 8 characters with a mix of letters and numbers.</p>
      </div>
      <div class="auth-orb"></div>
    </div>
  </div>
  <div class="auth-right">
    <div class="auth-form-wrap fade-up">
      <!-- Mobile logo (hidden on desktop via CSS) -->
      <div class="auth-mobile-logo" style="display:none">
        <div class="logo-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="white" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></div>
        FIRTA
      </div>
            <div class="auth-form-header">
        <h2>Reset Password</h2>
        <p>Enter your new password below.</p>
      </div>
      <% if (flash_error) { %><div class="alert alert-error" style="margin-bottom:1rem"><%= flash_error %></div><% } %>
      <form class="auth-form" action="/reset-password" method="POST">
        <input type="hidden" name="token" value="<%= token %>">
        <div class="form-group">
          <label class="form-label">New Password</label>
          <div class="input-wrap">
            <input type="password" id="password" name="password" class="form-input" placeholder="Min. 8 characters" required minlength="8" oninput="checkStrength(this.value)" />
            <button type="button" class="pw-toggle" onclick="togglePw('password',this)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="pw-hint" id="pwHint">At least 8 characters</div>
          <div class="pw-strength" id="pwStrength" style="display:none"><div class="pw-bar" id="pwBar"></div></div>
        </div>
        <div class="form-group">
          <label class="form-label">Confirm New Password</label>
          <div class="input-wrap">
            <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" placeholder="Repeat your password" required />
            <button type="button" class="pw-toggle" onclick="togglePw('confirmPassword',this)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        <button type="submit" class="btn btn-primary auth-submit">Set New Password</button>
      </form>
    </div>
  </div>
</div>
<script>
function togglePw(id,btn){const i=document.getElementById(id);i.type=i.type==='password'?'text':'password';btn.style.color=i.type==='text'?'var(--teal)':'';}
function checkStrength(val){
  const bar=document.getElementById('pwBar'),s=document.getElementById('pwStrength'),h=document.getElementById('pwHint');
  if(!val.length){s.style.display='none';return;}s.style.display='block';
  let score=0;if(val.length>=8)score++;if(/[A-Z]/.test(val))score++;if(/[0-9]/.test(val))score++;if(/[^A-Za-z0-9]/.test(val))score++;
  const c=['#e05252','#e07b3a','#f0c040','#0d9e82'],l=['Weak','Fair','Good','Strong'];
  bar.style.width=(score*25)+'%';bar.style.background=c[score-1]||'#e2ecea';
  h.textContent='Strength: '+(l[score-1]||'');h.style.color=c[score-1]||'';
}
</script>
</body>
</html>
