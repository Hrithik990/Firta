<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — FIRTA</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="dashboard-layout">


<div class="sidebar-overlay" id="sidebarOverlay"></div>
<button class="sidebar-toggle" id="sidebarToggle" aria-label="Menu">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
    <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
  </svg>
</button>
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="white" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
    </div>
    <span>FIRTA</span>
  </div>
  <div class="sidebar-label">NAVIGATION</div>
  <nav class="sidebar-nav">
    <a href="/dashboard" class="sidebar-link active">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </a>
    <a href="/add-item" class="sidebar-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 3H8l-2 4h12l-2-4z"/></svg>
      My Items
    </a>
    <a href="#" class="sidebar-link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2"/></svg>
      Settings
    </a>
  </nav>
  <div class="sidebar-user">
    <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
    <div class="user-info">
      <div class="user-name"><%= user.name %></div>
      <div class="user-plan"><%= user.plan.charAt(0).toUpperCase() + user.plan.slice(1) %> Plan</div>
    </div>
  </div>
  <a href="/add-item" class="btn btn-primary sidebar-reg-btn">Register New Item</a>
  <a href="/logout" class="logout-link">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    Log Out
  </a>
</aside>

<main class="main-content">
  <% if (flash_error) { %><div class="alert alert-error"><%= flash_error %></div><% } %>
  <% if (flash_success) { %><div class="alert alert-success"><%= flash_success %></div><% } %>

  <header class="main-header">
    <div>
      <h1>Welcome back, <%= user.name.split(' ')[0] %>!</h1>
      <p class="header-sub">Here is an overview of your protected property.</p>
    </div>
    <div class="header-actions">
      <a href="/add-item" class="btn btn-outline btn-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print QR Codes
      </a>
    </div>
  </header>

  <% if (items.length === 0) { %>
  <div class="quick-action-card">
    <div class="qa-icon">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
    </div>
    <div class="qa-label">QUICK ACTION</div>
    <h2 class="qa-title">Add Your First Item</h2>
    <p class="qa-sub">Secure your belongings in under 60 seconds.</p>
    <a href="/add-item" class="btn btn-primary">Get Started</a>
  </div>
  <% } %>

  <div class="stats-row">
    <div class="stat-box">
      <div class="stat-box-label">Total Items</div>
      <div class="stat-box-num"><%= stats.total || 0 %></div>
    </div>
    <div class="stat-box">
      <div class="stat-box-label">Active Tags</div>
      <div class="stat-box-num teal"><%= stats.active_tags || 0 %></div>
    </div>
    <div class="stat-box">
      <div class="stat-box-label">Lost Items</div>
      <div class="stat-box-num orange"><%= stats.lost_items || 0 %></div>
    </div>
  </div>

  <% if (items.length > 0) { %>
  <div class="items-table-card">
    <div class="table-header">
      <h2>Recent Protected Items</h2>
    </div>
    <table class="items-table">
      <thead>
        <tr>
          <th>Item Name</th>
          <th>ID / Tag</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach(item => { %>
        <tr>
          <td>
            <div class="item-cell">
              <div class="item-icon item-icon--<%= item.category.toLowerCase().replace(/\s+/g,'-') %>">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
              </div>
              <div>
                <div class="item-name"><%= item.name %></div>
                <div class="item-cat"><%= item.category %></div>
              </div>
            </div>
          </td>
          <td class="item-id"><%= item.tag_id %></td>
          <td>
            <% if (item.status === 'lost') { %>
              <span class="badge badge-lost">Lost</span>
            <% } else if (item.status === 'found') { %>
              <span class="badge badge-found">Found</span>
            <% } else { %>
              <span class="badge badge-pending">Active</span>
            <% } %>
          </td>
          <td>
            <a href="/item/<%= item.tag_id %>" class="btn btn-outline btn-sm">View QR</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</main>
<script src="/js/mobile.js"></script>
</body>
</html>
