<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — FIRTA</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-body">

<div class="auth-layout">

  <!-- LEFT PANEL -->
  <div class="auth-left">
    <div class="auth-left-overlay"></div>
    <div class="auth-left-content">
      <div class="auth-logo">
        <div class="auth-logo-icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="white" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
        </div>
        <span>FIRTA</span>
      </div>
      <div class="auth-left-hero">
        <h1>Reuniting you with<br>what matters.</h1>
        <p>Join the world's most reliable lost-and-found network. Secure, empathetic, and efficient.</p>
      </div>
      <div class="auth-trust-bar">
        <div class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          Trusted by 2M+ Users
        </div>
        <div class="trust-sep">·</div>
        <div class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20"/></svg>
          Global Coverage
        </div>
        <div class="trust-sep">·</div>
        <div class="trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          24/7 Recovery Support
        </div>
      </div>
    </div>
    <!-- Glowing orb decoration -->
    <div class="auth-orb"></div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="auth-right">
    <div class="auth-form-wrap fade-up">
      <% if (flash_error) { %><div class="alert alert-error" style="margin-bottom:1rem"><%= flash_error %></div><% } %>
      <% if (flash_success) { %><div class="alert alert-success" style="margin-bottom:1rem"><%= flash_success %></div><% } %>
      <div class="auth-form-header">
        <h2>Welcome back</h2>
        <p>Secure access to your FIRTA dashboard</p>
      </div>

      <form class="auth-form" action="/login" method="POST">
        <div class="form-group">
          <label class="form-label" for="email">Email Address</label>
          <div class="input-wrap">
            <input type="email" id="email" name="email" class="form-input" placeholder="name@company.com" required />
          </div>
        </div>

        <div class="form-group">
          <div class="pw-label-row">
            <label class="form-label" for="password">Password</label>
            <a href="#" class="forgot-link">Forgot Password?</a>
          </div>
          <div class="input-wrap">
            <input type="password" id="password" name="password" class="form-input" value="••••••••" required />
            <button type="button" class="pw-toggle" onclick="togglePw('password', this)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <label class="remember-row">
          <input type="checkbox" class="remember-check" />
          <span class="remember-label">Remember me for 30 days</span>
        </label>

        <button type="submit" class="btn btn-primary auth-submit">
          Sign In
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>

      <p class="auth-switch">
        Don't have an account? <a href="/signup">Sign Up</a>
      </p>

      <div class="auth-status">
        <span class="status-dot"></span>
        All Systems Operational
      </div>
    </div>
  </div>

</div>

<script>
function togglePw(id, btn) {
  const input = document.getElementById(id);
  const isHidden = input.type === 'password';
  input.type = isHidden ? 'text' : 'password';
  if (input.value === '••••••••') input.value = '';
  btn.style.color = isHidden ? 'var(--teal)' : '';
}
</script>
<script src="/js/mobile.js"></script>
</body>
</html>
