<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Found Item — FIRTA</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/finder.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
</head>
<body>
<nav class="nav">
  <a href="/" class="nav-logo">
    <div class="logo-icon"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="white" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></div>
    FIRTA
  </a>
  <a href="/login" class="nav-cta">Protect My Item</a>
</nav>

<main class="finder-page">
  <div class="finder-mode-badge">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    Finder Assistance Mode
  </div>

  <div class="finder-hero">
    <h1 class="finder-title">Thank you for being a hero.</h1>
    <p class="finder-sub">You've found a lost item protected by FIRTA. Let's get it home safely.</p>
  </div>

  <!-- Location status bar -->
  <div class="location-bar" id="locationBar">
    <div class="loc-spinner"></div>
    <span id="locationStatus">Detecting your location to help the owner...</span>
  </div>

  <div class="finder-content">
    <!-- Left: Item Card -->
    <div class="item-detail-card fade-up">
      <div class="item-img-wrap">
        <div class="active-recovery-badge">
          <span class="pulse-dot"></span>
          <% if (item.lost_mode) { %>
            🔴 Lost Mode Active
          <% } else { %>
            Active Recovery
          <% } %>
        </div>
        <div class="item-img-placeholder">
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgba(13,158,130,0.4)" stroke-width="1.2"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
        </div>
      </div>

      <div class="item-info-panel">
        <div class="item-info-header">
          <div>
            <h2 class="found-item-title">Found Item: <%= item.name %></h2>
            <p class="found-item-serial">Tag: <%= item.tag_id %> · <%= item.category %></p>
          </div>
          <% if (item.lost_mode) { %>
          <div class="translated-badge" style="background:#fff1f0;color:var(--danger);border-color:#fdd">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 000 16"/></svg>
            Reported Lost
          </div>
          <% } else { %>
          <div class="translated-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure Channel
          </div>
          <% } %>
        </div>

        <% if (item.finder_message) { %>
        <blockquote class="owner-message">"<%= item.finder_message %>"</blockquote>
        <% } %>

        <!-- ── OWNER CONTACT (only shown when Lost Mode is ON) ── -->
        <% if (ownerContact) { %>
        <div class="owner-contact-card">
          <div class="contact-card-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Owner Contact Info
            <span class="contact-verified-badge">✓ Verified</span>
          </div>
          <div class="contact-detail">
            <div class="contact-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span><strong>Name:</strong> <%= ownerContact.name %></span>
            </div>
            <% if (ownerContact.phone) { %>
            <div class="contact-row">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.9 11.5 19.79 19.79 0 01.86 2.82 2 2 0 012.84.84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.09 8.49a16 16 0 006.29 6.29l1.81-1.81a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              <span><strong>Phone:</strong>
                <a href="tel:<%= ownerContact.phone %>" class="phone-link"><%= ownerContact.phone %></a>
              </span>
            </div>
            <a href="tel:<%= ownerContact.phone %>" class="btn btn-primary contact-btn" style="margin-top:0.75rem;width:100%;justify-content:center">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.9 11.5 19.79 19.79 0 01.86 2.82 2 2 0 012.84.84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.09 8.49a16 16 0 006.29 6.29l1.81-1.81a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              Call Owner Now
            </a>
            <% } else { %>
            <p class="no-phone-note">No phone number added. Use the message form below to contact the owner.</p>
            <% } %>
          </div>
        </div>
        <% } else { %>
        <!-- Lost mode is OFF — contact info hidden -->
        <div class="contact-hidden-card">
          <div class="contact-hidden-icon">🔒</div>
          <div>
            <strong>Owner contact is private</strong>
            <p>The owner hasn't reported this item as lost yet. Send a message below and they'll be notified by email.</p>
          </div>
        </div>
        <% } %>

        <!-- Message form — always visible -->
        <div id="msgFormWrap" style="margin-top:1.25rem">
          <div class="msg-form-card">
            <div class="msg-form-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              Send a secure message to the owner
            </div>
            <div class="msg-input-group">
              <label class="msg-input-label">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Your Name
              </label>
              <input type="text" id="finderName" class="msg-input" placeholder="e.g. Ram Sharma (optional)" />
            </div>
            <div class="msg-input-group">
              <label class="msg-input-label">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                Your Message
              </label>
              <textarea id="msgText" class="msg-textarea" placeholder="e.g. Hi, I found your watch near Thamel, Kathmandu. I can meet anytime this week..." rows="4"></textarea>
            </div>
          </div>
          <button class="btn btn-primary contact-btn" onclick="sendMessage()" id="sendBtn" style="width:100%;justify-content:center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Send Secure Message to Owner
          </button>
          <div id="msgSuccess" style="display:none" class="msg-success-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Message sent! The owner has been notified by email.
          </div>
        </div>

        <div class="privacy-notice" style="margin-top:1rem">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <p><strong>Your Privacy Matters:</strong> Your contact info stays hidden. All communications go through FIRTA's encrypted bridge.</p>
        </div>
      </div>
    </div>

    <!-- Right: Next Steps + Map -->
    <div class="next-steps-card fade-up fade-up-2">
      <h3 class="next-steps-title">Next Steps</h3>
      <div class="steps-list">
        <div class="next-step">
          <div class="next-step-num">1</div>
          <div class="next-step-body">
            <h4>Secure the Item</h4>
            <p>Keep it safe and dry until the owner responds.</p>
          </div>
        </div>
        <div class="next-step">
          <div class="next-step-num">2</div>
          <div class="next-step-body">
            <h4><% if (ownerContact && ownerContact.phone) { %>Call or Message<% } else { %>Send a Message<% } %></h4>
            <p><% if (ownerContact && ownerContact.phone) { %>Call the owner directly or send a message — they'll get an email instantly.<% } else { %>Let the owner know where you found it — they'll get an email instantly.<% } %></p>
          </div>
        </div>
        <div class="next-step">
          <div class="next-step-num">3</div>
          <div class="next-step-body">
            <h4>Arrange Meeting</h4>
            <p>Meet in a public place — a coffee shop or police station lobby is ideal.</p>
          </div>
        </div>
      </div>

      <!-- Live location map -->
      <div class="finder-map-wrap" id="finderMapWrap" style="display:none">
        <div class="finder-map-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 000 16"/></svg>
          Your current location
        </div>
        <div id="finderMap" style="height:200px;border-radius:10px;overflow:hidden"></div>
        <p class="finder-map-note">This location will be shared with the owner when you send a message.</p>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/mobile.js"></script>
<script>
const TAG_ID  = '<%= tagId %>';
const SCAN_ID = '<%= scanId || "" %>';

// Location state
let userLat      = null;
let userLng      = null;
let locationName = null;
let locationDone = false;  // true once geolocation resolves (success OR failure)
let finderMap    = null;

// ── Geolocation ──────────────────────────────────────────────
function initLocation() {
  if (!navigator.geolocation) {
    locationDone = true;
    setLocationStatus('Location not available on this device.', false);
    return;
  }

  // Show loading state on send button too
  const btn = document.getElementById('sendBtn');
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = `
      <svg width="14" height="14" style="animation:spin 0.8s linear infinite;flex-shrink:0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
      </svg>
      Getting your location...`;
  }

  navigator.geolocation.getCurrentPosition(
    async (pos) => {
      userLat = pos.coords.latitude;
      userLng = pos.coords.longitude;

      // Reverse geocode
      try {
        const r = await fetch(
          `https://nominatim.openstreetmap.org/reverse?lat=${userLat}&lon=${userLng}&format=json`,
          { headers: { 'Accept-Language': 'en' } }
        );
        const d = await r.json();
        locationName = d.display_name
          ? d.display_name.split(',').slice(0, 3).join(',').trim()
          : `${userLat.toFixed(4)}, ${userLng.toFixed(4)}`;
      } catch (e) {
        locationName = `${userLat.toFixed(4)}, ${userLng.toFixed(4)}`;
      }

      setLocationStatus('📍 ' + locationName, true);
      showFinderMap(userLat, userLng);

      // Update scan record with location
      if (SCAN_ID) {
        fetch(`/finder/${TAG_ID}/scan-location`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({
            scanId: SCAN_ID,
            latitude: userLat,
            longitude: userLng,
            locationName,
          }),
        }).catch(() => {});
      }

      locationDone = true;
      enableSendButton();
    },
    (err) => {
      // Denied or timeout — still allow sending without location
      locationDone = true;
      setLocationStatus('Location access denied — location won\'t be shared.', false);
      enableSendButton();
    },
    { timeout: 10000, maximumAge: 60000 }
  );
}

function enableSendButton() {
  const btn = document.getElementById('sendBtn');
  if (!btn) return;
  btn.disabled = false;
  btn.innerHTML = `
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
      <polyline points="22,6 12,13 2,6"/>
    </svg>
    Send Secure Message to Owner`;
}

function setLocationStatus(msg, success) {
  const bar = document.getElementById('locationBar');
  const txt = document.getElementById('locationStatus');
  if (!bar || !txt) return;
  txt.textContent = msg;
  bar.classList.toggle('location-bar--success', success);
  bar.classList.toggle('location-bar--denied', !success);
  const spinner = bar.querySelector('.loc-spinner');
  if (spinner) spinner.style.display = 'none';
}

function showFinderMap(lat, lng) {
  const wrap = document.getElementById('finderMapWrap');
  if (!wrap) return;
  wrap.style.display = 'block';
  if (finderMap) { finderMap.remove(); finderMap = null; }
  finderMap = L.map('finderMap', {
    zoomControl: true, attributionControl: false,
  }).setView([lat, lng], 15);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(finderMap);
  L.circleMarker([lat, lng], {
    radius: 10, fillColor: '#0d9e82',
    color: 'white', weight: 3, fillOpacity: 1,
  }).addTo(finderMap).bindPopup('You are here').openPopup();
}

// ── Send message ─────────────────────────────────────────────
async function sendMessage() {
  const msgEl  = document.getElementById('msgText');
  const nameEl = document.getElementById('finderName');
  const msg    = msgEl.value.trim();
  const name   = nameEl ? nameEl.value.trim() : '';

  if (!msg) {
    msgEl.style.borderColor = 'var(--danger)';
    msgEl.focus();
    return;
  }
  msgEl.style.borderColor = '';

  const btn = document.getElementById('sendBtn');
  btn.disabled = true;
  btn.innerHTML = `
    <div style="width:16px;height:16px;border:2px solid rgba(255,255,255,0.4);border-top-color:white;border-radius:50%;animation:spin 0.8s linear infinite;flex-shrink:0"></div>
    Sending...`;

  try {
    const res = await fetch(`/finder/${TAG_ID}/message`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({
        message:      msg,
        finderName:   name || 'Anonymous',
        latitude:     userLat,      // will be null if location denied — that's OK
        longitude:    userLng,
        locationName: locationName,
      }),
    });
    const data = await res.json();
    if (data.ok) {
      document.querySelector('.msg-form-card').style.display = 'none';
      btn.style.display = 'none';
      const successEl = document.getElementById('msgSuccess');
      if (successEl) successEl.style.display = 'flex';
    } else {
      btn.disabled = false;
      enableSendButton();
      alert('Could not send message. Please try again.');
    }
  } catch (e) {
    btn.disabled = false;
    enableSendButton();
    alert('Network error. Please check your connection and try again.');
  }
}

document.addEventListener('DOMContentLoaded', initLocation);
</script>
</body>
</html>
