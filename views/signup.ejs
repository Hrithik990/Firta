<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Account — FIRTA</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-body">

<div class="auth-layout">

  <!-- LEFT PANEL -->
  <div class="auth-left auth-left--teal">
    <div class="auth-left-content">
      <div class="auth-logo auth-logo--white">
        <div class="auth-logo-icon auth-logo-icon--white">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--teal)" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
        </div>
        <span>FIRTA</span>
      </div>
      <div class="auth-left-hero auth-left-hero--teal">
        <h1>Lost and Found,<br>Reimagined.</h1>
        <p>Join thousands of users who protect their valuables with FIRTA's smart QR technology and AI-driven recovery network.</p>
      </div>

      <div class="signup-features">
        <div class="signup-feature">
          <div class="sf-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h4>Advanced Security</h4>
            <p>Encrypted communication between finders and owners. No personal phone numbers or emails ever exposed.</p>
          </div>
        </div>
        <div class="signup-feature">
          <div class="sf-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20"/></svg>
          </div>
          <div>
            <h4>Global Reach</h4>
            <p>A community-powered network that works worldwide. If your item is found, you'll know instantly through real-time pings.</p>
          </div>
        </div>
        <div class="signup-feature">
          <div class="sf-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div>
            <h4>AI Assistant</h4>
            <p>Our proprietary AI helps finders provide more accurate descriptions and suggests the best return methods automatically.</p>
          </div>
        </div>
      </div>

      <div class="signup-img-preview">
        <div class="sip-inner">
          <div class="sip-qr">
            <svg viewBox="0 0 60 60" width="50" height="50">
              <rect x="2" y="2" width="24" height="24" fill="none" stroke="white" stroke-width="3" rx="2"/>
              <rect x="9" y="9" width="10" height="10" fill="white" rx="1"/>
              <rect x="34" y="2" width="24" height="24" fill="none" stroke="white" stroke-width="3" rx="2"/>
              <rect x="41" y="9" width="10" height="10" fill="white" rx="1"/>
              <rect x="2" y="34" width="24" height="24" fill="none" stroke="white" stroke-width="3" rx="2"/>
              <rect x="9" y="41" width="10" height="10" fill="white" rx="1"/>
              <rect x="34" y="34" width="6" height="6" fill="white" rx="1"/>
              <rect x="44" y="34" width="6" height="6" fill="white" rx="1"/>
              <rect x="34" y="44" width="6" height="6" fill="white" rx="1"/>
              <rect x="44" y="44" width="6" height="6" fill="white" rx="1"/>
              <rect x="54" y="34" width="6" height="6" fill="white" rx="1"/>
              <rect x="54" y="44" width="6" height="6" fill="white" rx="1"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="auth-right">
    <div class="auth-form-wrap fade-up">
      <% if (flash_error) { %><div class="alert alert-error" style="margin-bottom:1rem"><%= flash_error %></div><% } %>
      <div class="auth-form-header">
        <h2>Create Account</h2>
        <p>Start protecting your belongings in minutes.</p>
      </div>

      <form class="auth-form" action="/signup" method="POST">
        <div class="form-group">
          <label class="form-label" for="fullName">Full Name</label>
          <input type="text" id="fullName" name="fullName" class="form-input" placeholder="John Doe" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Email Address</label>
          <input type="email" id="email" name="email" class="form-input" placeholder="name@company.com" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" class="form-input" placeholder="+1 (555) 000-0000" />
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <div class="input-wrap">
            <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required minlength="8" oninput="checkStrength(this.value)" />
            <button type="button" class="pw-toggle" onclick="togglePw('password', this)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="pw-hint" id="pwHint">Password must be at least 8 characters</div>
          <div class="pw-strength" id="pwStrength" style="display:none">
            <div class="pw-bar" id="pwBar"></div>
          </div>
        </div>

        <button type="submit" class="btn btn-primary auth-submit">
          Create Account
        </button>

        <p class="auth-terms">
          By signing up, you agree to our <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
        </p>
      </form>

      <p class="auth-switch">
        Already have an account? <a href="/login">Log In</a>
      </p>
    </div>
  </div>

</div>

<script>
function togglePw(id, btn) {
  const input = document.getElementById(id);
  input.type = input.type === 'password' ? 'text' : 'password';
  btn.style.color = input.type === 'text' ? 'var(--teal)' : '';
}

function checkStrength(val) {
  const bar = document.getElementById('pwBar');
  const strength = document.getElementById('pwStrength');
  const hint = document.getElementById('pwHint');
  if (val.length === 0) { strength.style.display = 'none'; return; }
  strength.style.display = 'block';
  let score = 0;
  if (val.length >= 8) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const levels = ['#e05252', '#e07b3a', '#f0c040', '#0d9e82'];
  const labels = ['Weak', 'Fair', 'Good', 'Strong'];
  bar.style.width = (score * 25) + '%';
  bar.style.background = levels[score - 1] || '#e2ecea';
  hint.textContent = 'Strength: ' + (labels[score - 1] || '');
  hint.style.color = levels[score - 1] || '';
}
</script>
<script src="/js/mobile.js"></script>
</body>
</html>
