<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FIRTA — Scan. Connect. Return.</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/landing.css">
</head>
<body>

<%- include('partials/nav') %>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-eyebrow fade-up">🌍 Trusted in 120+ countries</div>
      <h1 class="hero-title fade-up fade-up-1">
        Scan.<br>
        <span class="hero-title-accent">Connect.</span><br>
        Return.
      </h1>
      <p class="hero-subtitle fade-up fade-up-2">
        The world's most empathetic lost-and-found system. Protect your valuables with AI-powered recovery tools and global translation support.
      </p>
      <div class="hero-actions fade-up fade-up-3">
        <a href="/login" class="btn btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12l7-7 7 7"/></svg>
          Protect My Item
        </a>
        <a href="#how-it-works" class="btn btn-outline">Learn How It Works</a>
      </div>
    </div>
    <div class="hero-visual fade-up fade-up-2">
      <div class="hero-phone-wrap">
        <div class="hero-card-float">
          <div class="qr-preview">
            <svg viewBox="0 0 100 100" width="90" height="90">
              <rect x="5" y="5" width="35" height="35" fill="none" stroke="var(--teal)" stroke-width="4" rx="3"/>
              <rect x="15" y="15" width="15" height="15" fill="var(--teal)" rx="1"/>
              <rect x="60" y="5" width="35" height="35" fill="none" stroke="var(--teal)" stroke-width="4" rx="3"/>
              <rect x="70" y="15" width="15" height="15" fill="var(--teal)" rx="1"/>
              <rect x="5" y="60" width="35" height="35" fill="none" stroke="var(--teal)" stroke-width="4" rx="3"/>
              <rect x="15" y="70" width="15" height="15" fill="var(--teal)" rx="1"/>
              <rect x="55" y="55" width="8" height="8" fill="var(--teal)" rx="1"/>
              <rect x="68" y="55" width="8" height="8" fill="var(--teal)" rx="1"/>
              <rect x="81" y="55" width="8" height="8" fill="var(--teal)" rx="1"/>
              <rect x="55" y="68" width="8" height="8" fill="var(--teal)" rx="1"/>
              <rect x="81" y="68" width="8" height="8" fill="var(--teal)" rx="1"/>
              <rect x="55" y="81" width="8" height="8" fill="var(--teal)" rx="1"/>
              <rect x="68" y="81" width="8" height="8" fill="var(--teal)" rx="1"/>
              <rect x="81" y="81" width="8" height="8" fill="var(--teal)" rx="1"/>
            </svg>
          </div>
          <span class="hero-card-label">FIRTA Protected</span>
        </div>
        <div class="hero-translate-bubble">
          <span>Found your bag!</span>
          <span class="bubble-translated">¡He encontrado tu maleta!</span>
        </div>
        <div class="hero-img-wrap">
          <div class="hero-img-bg"></div>
          <div class="hero-img-content">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="1.2" opacity="0.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how" id="how-it-works">
  <div class="section-inner">
    <div class="section-header">
      <h2 class="section-title">How It Works</h2>
      <p class="section-sub">Five simple steps to never losing your peace of mind again.</p>
    </div>
    <div class="steps-row">
      <div class="step-item">
        <div class="step-num">1</div>
        <h3>Register</h3>
        <p>Add your item to the FIRTA ecosystem.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-item">
        <div class="step-num">2</div>
        <h3>Generate</h3>
        <p>Create a unique, dynamic QR identity.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-item">
        <div class="step-num">3</div>
        <h3>Attach</h3>
        <p>Place the tag on your valuable item.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-item">
        <div class="step-num">4</div>
        <h3>Scan</h3>
        <p>Finder scans and contacts you securely.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-item">
        <div class="step-num">5</div>
        <h3>Return</h3>
        <p>Item returned safely through our portal.</p>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features" id="features">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-eyebrow">Powered by Intelligence</div>
      <h2 class="section-title">Our AI tools bridge the gap<br>between finders and owners.</h2>
    </div>
    <div class="features-grid">
      <div class="feature-card feature-card--large">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/></svg>
        </div>
        <h3>Universal Translation</h3>
        <p>Lost your luggage in Tokyo? Our AI translates finder communications in real-time between 100+ languages, ensuring empathy is never lost in translation.</p>
        <div class="feature-demo">
          <div class="bubble bubble-en">Found your bag! 👜</div>
          <div class="bubble bubble-es">¡He encontrado tu maleta!</div>
        </div>
      </div>
      <div class="feature-card feature-card--accent">
        <div class="feature-icon feature-icon--white">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18"/></svg>
        </div>
        <h3>Smart Finder Help</h3>
        <p>Our AI guides finders through the safest and most efficient return process based on local logistics and safety protocols.</p>
        <a href="/finder/demo" class="btn btn-sm" style="background:rgba(255,255,255,0.2);color:white;border:none;margin-top:1rem">Explore Tools →</a>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Identity Cloaking</h3>
        <p>Connect without sharing phone numbers or personal emails. Our encrypted bridge keeps you private until you decide otherwise.</p>
      </div>
      <div class="feature-card feature-card--map">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <h3>Global Reach</h3>
        <p>From New York to Nairobi, FIRTA works wherever you are. No subscription, no batteries, just pure connection.</p>
        <div class="globe-dots"></div>
      </div>
    </div>
  </div>
</section>

<!-- IMPACT -->
<section class="impact" id="impact">
  <div class="section-inner">
    <div class="impact-inner">
      <div class="impact-text">
        <div class="section-eyebrow">Real Impact</div>
        <h2>Connecting people,<br>returning memories.</h2>
        <p>Every item returned is a story of human kindness. FIRTA has helped reunite people with their most treasured belongings across 6 continents.</p>
        <a href="/login" class="btn btn-primary" style="margin-top:1.5rem">Start Protecting →</a>
      </div>
      <div class="impact-stats">
        <div class="stat-card">
          <div class="stat-num">98%</div>
          <div class="stat-label">Recovery Rate</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">120+</div>
          <div class="stat-label">Countries</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">2M+</div>
          <div class="stat-label">Items Protected</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">100+</div>
          <div class="stat-label">Languages</div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script src="/js/mobile.js"></script>
</body>
</html>
