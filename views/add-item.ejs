<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add New Item — FIRTA</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/add-item.css">
</head>
<body>
<nav class="nav">
  <a href="/" class="nav-logo">
    <div class="logo-icon"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="white" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></div>
    FIRTA
  </a>
  <div class="nav-links"><a href="/dashboard">← Dashboard</a></div>
  <a href="/logout" class="nav-cta" style="background:var(--border);color:var(--text-2)">Log Out</a>
</nav>

<main class="add-item-page">
  <div class="add-item-container fade-up">
    <div class="step-progress">
      <div class="progress-step active"><span>1</span> Item Details</div>
      <div class="progress-line"></div>
      <div class="progress-step"><span>2</span> AI Review</div>
      <div class="progress-line"></div>
      <div class="progress-step"><span>3</span> Generate QR</div>
    </div>

    <% if (flash_error) { %>
    <div class="alert alert-error" style="margin-bottom:1rem"><%= flash_error %></div>
    <% } %>

    <div class="form-card">
      <h1 class="form-title">Add New Item</h1>
      <form action="/add-item" method="POST">

        <div class="form-group">
          <label class="form-label" for="itemName">Item Name</label>
          <input type="text" id="itemName" name="itemName" class="form-input" placeholder="e.g. Vintage Leather Wallet" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="category">Category</label>
          <div class="select-wrap">
            <select id="category" name="category" class="form-select">
              <option>Electronics</option>
              <option>Travel</option>
              <option>Personal</option>
              <option>Keys</option>
              <option>Bags & Luggage</option>
              <option>Documents</option>
              <option>Jewelry</option>
              <option>Other</option>
            </select>
            <svg class="select-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>

        <div class="form-group">
          <div class="desc-header">
            <label class="form-label" for="description">Description</label>
            <button type="button" class="ai-gen-btn" id="aiGenBtn" onclick="aiGenerateDesc()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              AI Generate Description
            </button>
          </div>
          <textarea id="description" name="description" class="form-textarea" placeholder="Briefly describe your item..."></textarea>
          <div class="ai-hint" id="aiHint" style="display:none"><div class="ai-spinner"></div> AI is writing your description...</div>
        </div>

        <div class="form-group">
          <label class="form-label" for="finderMessage">Message for Finder</label>
          <textarea id="finderMessage" name="finderMessage" class="form-textarea" placeholder="Add a personal message for whoever finds this item..."></textarea>
        </div>

        <div class="form-actions">
          <a href="/dashboard" class="btn btn-outline">Cancel</a>
          <button type="submit" class="btn btn-primary">
            Register & Generate QR
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script>
function aiGenerateDesc() {
  const name = document.getElementById('itemName').value || 'item';
  const cat  = document.getElementById('category').value;
  const ta   = document.getElementById('description');
  const hint = document.getElementById('aiHint');
  const btn  = document.getElementById('aiGenBtn');
  btn.disabled = true; hint.style.display = 'flex'; ta.value = '';
  const map = {
    Electronics: `${name} — a personal electronic device. Contains important personal data. Please contact the owner immediately if found.`,
    Travel: `${name} — a travel item containing personal belongings. Owner will be very grateful and can offer a reward for safe return.`,
    Keys: `${name} — a set of keys. Their loss causes significant inconvenience. Reward offered for return.`,
    default: `${name} — a personal belonging registered with FIRTA. Please use this tag to securely contact the owner.`
  };
  setTimeout(() => {
    hint.style.display = 'none';
    ta.value = map[cat] || map.default;
    btn.disabled = false;
    ta.style.borderColor = 'var(--teal)';
    setTimeout(() => ta.style.borderColor = '', 2000);
  }, 1600);
}
</script>
<script src="/js/mobile.js"></script>
</body>
</html>
