<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password — FIRTA</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-body">
<div class="auth-layout">
  <div class="auth-left">
    <div class="auth-left-overlay"></div>
    <div class="auth-left-content">
      <div class="auth-logo">
        <div class="auth-logo-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="white" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></div>
        FIRTA
      </div>
      <div class="auth-left-hero">
        <h1>No worries,<br>we've got you.</h1>
        <p>Enter your email and we'll send a secure link to reset your password.</p>
      </div>
      <div class="auth-orb"></div>
    </div>
  </div>
  <div class="auth-right">
    <div class="auth-form-wrap fade-up">
      <!-- Mobile logo (hidden on desktop via CSS) -->
      <div class="auth-mobile-logo" style="display:none">
        <div class="logo-icon"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="white" stroke-width="2.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg></div>
        FIRTA
      </div>
            <div class="auth-form-header">
        <h2>Forgot Password</h2>
        <p>We'll send a reset link to your email.</p>
      </div>
      <% if (flash_error) { %><div class="alert alert-error" style="margin-bottom:1rem"><%= flash_error %></div><% } %>
      <% if (flash_success) { %><div class="alert alert-success" style="margin-bottom:1rem"><%= flash_success %></div><% } %>
      <form class="auth-form" action="/forgot-password" method="POST">
        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-input" placeholder="name@company.com" required />
        </div>
        <button type="submit" class="btn btn-primary auth-submit">
          Send Reset Link
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
      <p class="auth-switch"><a href="/login">← Back to Login</a></p>
    </div>
  </div>
</div>
</body>
</html>
